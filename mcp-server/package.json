{
  "name": "later-mcp",
  "version": "0.3.1",
  "description": "MCP server for managing a later-queue of deferred actions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "later-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --minify --outfile=dist/index.js",
    "dev": "esbuild src/index.ts --bundle --platform=node --format=esm --minify --outfile=dist/index.js --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0"
}
